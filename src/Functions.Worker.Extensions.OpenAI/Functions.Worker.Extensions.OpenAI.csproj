<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>netstandard2.1</TargetFramework>
    <Description>Microsoft Azure Functions .NET Isolated Worker Extension for OpenAI</Description>
    <PackageId>Streeka.Azure.Functions.OpenAI.Extension</PackageId>
    <Version>0.19.0-alpha-streeka.4</Version>
    <WebJobsVersion Condition="'$(WebJobsVersion)' == ''">0.19.0-alpha-streeka.4</WebJobsVersion>
    <RepositoryUrl>https://github.com/samsutherland/azure-functions-openai-extension</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Azure.AI.OpenAI" Version="2.1.0" />
    <PackageReference Include="Microsoft.Azure.Functions.Worker.Core" Version="2.0.0" />
    <PackageReference Include="Microsoft.Azure.Functions.Worker.Extensions.Abstractions" Version="1.3.0" />
  </ItemGroup>

  <ItemGroup>
    <AssemblyAttribute Include="Microsoft.Azure.Functions.Worker.Extensions.Abstractions.ExtensionInformationAttribute">
      <_Parameter1>Streeka.Azure.WebJobs.Extensions.OpenAI</_Parameter1>
      <_Parameter2>$(WebJobsVersion)</_Parameter2>
    </AssemblyAttribute>
  </ItemGroup>
</Project>
